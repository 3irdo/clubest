---
import { Navbar } from "../components/navigation/Navbar";
import { Sidebar } from "../components/navigation/Sidebar";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml"  />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>CLUBEST | {title}</title>
  </head>
  <body class="bg-slate-50 font-sans text-gray-900">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <div class="hidden md:block transition-all duration-300 shadow-xl z-20">
        <Sidebar client:load />
      </div>

      <!-- Main Content Area -->
      <div class="flex-1 flex flex-col overflow-hidden relative">
        <header class="z-10 shadow-sm relative">
            <Navbar client:load isLanding={false}/>
        </header>
        
        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-slate-50 p-6 md:p-8 lg:p-10">
          <div class="max-w-6xl mx-auto">
            <slot />
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
